from news_scraper import get_news

def generate_script():

    news = get_news()

    script = "Welcome to CyberCrow Podcast by Steven Bush.\n\n"
    script += "Today's Cybersecurity Intelligence Briefing:\n\n"

    for item in news:
        script += f"- {item}\n"

    script += "\nStay cyber aware. This is CyberCrow signing off."

    return script
